---
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LinkButton from "@/components/LinkButton.astro";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;

const experience = [
  {
    role: "AI Evaluation Engineer",
    company: "Bespoke Labs",
    period: "03/2026",
    bullets: [
      "Contributed task authorship to OpenThoughts, Bespoke Labs' open reasoning dataset initiative.",
      "Designed Harbor-format Terminal Bench style tasks covering concurrency bugs, semaphore leaks, and write-ordering failures.",
      "Applied Bespoke-MiniCheck for claim-level factual grounding using NLI-based verification.",
    ],
  },
  {
    role: "Builder and AI Systems Engineer",
    company: "Promco",
    period: "03/2026",
    bullets: [
      "Building an order-to-approval system for liquor distributors that turns WhatsApp orders into commercially reviewable drafts.",
      "Designed explicit state machines and durable session handling for compliance-sensitive order flows.",
      "Built typed tool interfaces, versioned prompts, validation, and failure tracing around irreversible business actions.",
    ],
  },
  {
    role: "AI Training and Model Evaluation Engineer",
    company: "AfterQuery",
    period: "08/2025",
    bullets: [
      "Conducted frontier model evaluations for logic correctness, security, and infrastructure workflows.",
      "Built Project Anvil evaluation environments using base snapshots, gold patches, and automated oracles.",
      "Created Terminal Bench v2 tasks for concurrency bugs, security vulnerabilities, and infra debugging.",
    ],
  },
  {
    role: "Backend Engineer",
    company: "Alcora",
    period: "02/2025 - 09/2025",
    bullets: [
      "Architected a multi-tenant headless ERP with real-time stock and demand intelligence.",
      "Built payment rails with automated debt reconciliation across brands, distributors, and retailers.",
      "Reduced promotional wastage by 40% with promo cost versus incremental gross profit tracking.",
    ],
  },
  {
    role: "Founding Engineer",
    company: "AfyaTelemed",
    period: "05/2024 - 07/2025",
    bullets: [
      "Architected a telemedicine platform across triage, consultations, pharmacy, and lab integration.",
      "Built secure video consultation with WebRTC and payment processing across local and international gateways.",
    ],
  },
  {
    role: "Software Engineer",
    company: "McSystems & Medical Inc.",
    period: "04/2024 - 10/2024",
    bullets: [
      "Architected a CRM with voice-to-CRM logging, reducing manual data entry by 70%.",
      "Rebuilt a legacy PHP medical sales marketplace into an offline-first Next.js platform.",
    ],
  },
];

const projects = [
  {
    title: "CareWeave",
    subtitle: "AI-Native Healthcare Coordination Platform",
    detail:
      "An AI-native platform that transforms fragmented, unstructured healthcare documents (images, referrals, scanned PDFs) into a grounded knowledge graph using vector embeddings and relationship-native reasoning. Automates provider-payer loops with low-latency voice agents and human-in-the-loop validation, building institutional memory that reduces referral delays and claim denials.",
    techStack: "Neo4j, Vector Embeddings, Liteparse, Low-latency Voice Agents, Human-in-the-loop Validation",
  },
  {
    title: "Taji",
    subtitle: "Real-Time AI Product Demo Agent",
    detail:
      "A 24/7 AI agent that joins video calls to deliver multilingual, interactive product demos. Drops into any SaaS product to navigate it via VLM-based agentic automation, qualifying leads and booking follow-ups directly in your CRM and calendar. Built on LiveKit, Deepgram, and Cartesia (<700ms perceived latency).",
    techStack: "Python, FastAPI, Effect-TS, LiveKit, Deepgram, Cartesia, VLM-based Agentic Automation",
  },
  {
    title: "CVCS",
    subtitle: "AI Cognition Version Control System",
    detail:
      "Version control for enterprise AI cognition and context. CVCS tracks decisions, corrections, and contexts to make agent behavior explicit, versioned, and portable—retaining organizational knowledge while keeping agent runtimes interchangeable.",
    techStack: "Go, PostgreSQL, Event-Driven Architecture",
  },
];

const skillGroups = [
  { category: "Languages", items: "TypeScript, Go, Python" },
  { category: "Frontend", items: "React, Next.js" },
  { category: "Backend", items: "FastAPI, Effect-TS, REST APIs, Workflow orchestrations, enterprise integrations" },
  { category: "AI Engineering", items: "Document Intelligence, Agentic Workflows, RAG, GraphRAG, AI Evals, Context Engineering, Model Context Protocol (MCP), A2A, Harness Engineering" },
  { category: "Data", items: "PostgreSQL, Neo4j, Vector Databases, SQL" },
  { category: "Automation & Integrations", items: "Playwright, Browser Automation, API Integrations, Event-Driven Systems" },
  { category: "Infrastructure", items: "Docker, Kubernetes, Cloudflare Workers" },
];
---

<Layout title={`Resume | ${config.site.title}`}>
  <Header />
  <main id="main-content" class="app-layout pb-12">
    <div class="flex items-center justify-between border-b border-border pb-5 pt-8 text-sm">
      <LinkButton
        href={getRelativeLocaleUrl(locale, "")}
        class="text-muted-foreground underline underline-offset-4 hover:text-accent"
      >
        Back home
      </LinkButton>
      <a
        href="/wilson-gichuhi-resume.pdf"
        target="_blank"
        class="font-medium underline underline-offset-4 hover:text-accent"
      >
        View PDF
      </a>
    </div>

    <section class="py-12">
      <p class="text-sm font-medium text-muted-foreground">Wilson Gichuhi</p>
      <h1 class="mt-4 text-4xl font-semibold tracking-tight text-foreground">
        Systems Engineer
      </h1>
      <p class="mt-6 text-lg leading-relaxed text-foreground/90">
        I build the integrations, orchestration layers, and data pipelines that make AI useful in production workflows—bringing reliable software design and robust infrastructure to connect capability models with real business operations.
      </p>
      <div class="mt-8 space-y-1 text-sm text-muted-foreground">
        <p>Nairobi, Kenya</p>
        <p>
          <a class="underline underline-offset-4 hover:text-accent" href="mailto:winchygichu@gmail.com">
            winchygichu@gmail.com
          </a>
        </p>
        <p>
          <a class="underline underline-offset-4 hover:text-accent" href="https://github.com/Qodestackr" target="_blank" rel="noreferrer">
            GitHub
          </a>
          {" "}/{" "}
          <a class="underline underline-offset-4 hover:text-accent" href="https://linkedin.com/in/wilson-gichuhi" target="_blank" rel="noreferrer">
            LinkedIn
          </a>
        </p>
      </div>
    </section>

    <section class="border-t border-border py-10">
      <h2 class="text-sm font-semibold uppercase tracking-widest text-muted-foreground">Experience</h2>
      <div class="mt-6 space-y-8">
        {experience.map((item) => (
          <article class="grid gap-2 sm:grid-cols-[9rem_1fr]">
            <p class="text-sm text-muted-foreground">{item.period}</p>
            <div>
              <h3 class="font-medium text-lg text-foreground">
                {item.role}, <span class="text-accent">{item.company}</span>
              </h3>
              <ul class="mt-3 list-disc space-y-2 pl-5 leading-relaxed text-muted-foreground">
                {item.bullets.map((bullet) => (
                  <li>{bullet}</li>
                ))}
              </ul>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="border-t border-border py-10">
      <h2 class="text-sm font-semibold uppercase tracking-widest text-muted-foreground">Projects</h2>
      <div class="mt-6 space-y-8">
        {projects.map((item) => (
          <article class="grid gap-2 sm:grid-cols-[9rem_1fr]">
            <p class="text-sm text-muted-foreground">{item.techStack}</p>
            <div>
              <h3 class="font-medium text-lg text-foreground">
                {item.title} <span class="text-accent">: {item.subtitle}</span>
              </h3>
              <p class="mt-2 leading-relaxed text-muted-foreground">{item.detail}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="border-t border-border py-10">
      <h2 class="text-sm font-semibold uppercase tracking-widest text-muted-foreground">Tools & Skills</h2>
      <div class="mt-6 grid gap-x-8 gap-y-6 sm:grid-cols-2">
        {skillGroups.map((group) => (
          <div>
            <h3 class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">{group.category}</h3>
            <p class="mt-2 text-sm text-foreground/90 leading-relaxed">{group.items}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="border-t border-border py-10">
      <h2 class="text-sm font-semibold uppercase tracking-widest text-muted-foreground">Education</h2>
      <p class="mt-6 leading-relaxed text-foreground/90">BSc. Computer Technology, JKUAT University. 2018 - 2023.</p>
    </section>
  </main>
  <Footer />
</Layout>
